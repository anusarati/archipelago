# Archipelago Agents - Example Configuration
# Copy this file to .env and fill in values as needed

# Environment type: local, dev, demo, prod
ENV=local

# Agent execution timeout (in seconds, default 12 hours)
AGENT_TIMEOUT_SECONDS=43200

# =============================================================================
# LLM Provider API Keys (at least one required)
# =============================================================================
# Anthropic
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Google (Gemini)
GOOGLE_API_KEY=

# OR use LiteLLM Proxy for all LLM requests
# LITELLM_PROXY_API_BASE=
# LITELLM_PROXY_API_KEY=

# Optional: HSN embedding endpoint override (used by openai Python client)
# HSN_EMBEDDING_MODEL=openai/text-embedding-3-small
# HSN_EMBEDDING_API_KEY=
# HSN_EMBEDDING_BASE_URL=https://api.openai.com/v1
# HSN_EMBEDDING_EXTRA_ARGS={"dimensions":1024}
# HSN_EMBEDDING_TIMEOUT_SECONDS=180
# HSN_MAX_EXTRACTED_TEXT_CHARS=131072
# HSN_MAX_EMBEDDING_TEXT_CHARS=131072
# Legacy fallback for both (prefer separate settings above):
# HSN_MAX_TEXT_CHARS=131072
# HSN_PDF_OCR_DPI=150
# HSN_PDF_OCR_MAX_PAGES=12
# HSN_PDF_OCR_LANG=eng
# HSN_PDF_OCR_CONFIG=--psm 6
# HSN_PDF_OCR_PAGE_TIMEOUT_SECONDS=20
# HSN_PDF_OCR_THREAD_COUNT=2

# =============================================================================
# Logging backends (all optional)
# =============================================================================
# File logging
FILE_LOGGING=false
FILE_LOG_PATH=

# Redis logging (for real-time streaming)
# REDIS_LOGGING=false
# REDIS_HOST=
# REDIS_PORT=6379

# Datadog APM
# DATADOG_LOGGING=false
# DATADOG_API_KEY=
