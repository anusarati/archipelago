# Archipelago Environment - Example Configuration
# Copy this file to .env and fill in values as needed

# Environment type: local, dev, demo, prod
ENV=local

# Datadog logging (optional)
DATADOG_LOGGING=false
DATADOG_API_KEY=
DATADOG_APP_KEY=

# MCP gateway readiness settings
# Timeout budget for MCP server warmup during POST /apps
MCP_READINESS_TIMEOUT_SECONDS=10
# Poll interval during readiness checks
MCP_READINESS_RETRY_INTERVAL_SECONDS=1

# S3 Configuration (optional - only needed for S3 snapshot upload/download)
# S3_SNAPSHOTS_BUCKET=snapshots
# S3_SNAPSHOTS_PREFIX=
# S3_DEFAULT_REGION=us-west-2
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
